---
import { getCollection } from 'astro:content';
import Desktop from '../layouts/Desktop.astro';
import Window from '../components/Window.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Desktop title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<div class="desktop-icons">
		<a class="desktop-icon" href="/blog">
			<span class="glyph">📖</span><span class="caption">My Articles</span>
		</a>
		<a class="desktop-icon" href="/about">
			<span class="glyph">ℹ️</span><span class="caption">About Me</span>
		</a>
		{
			posts.slice(0, 6).map((post) => (
				<a class="desktop-icon" href={`/blog/${post.id}/`}>
					<span class="glyph">📄</span>
					<span class="caption">{post.data.title}</span>
				</a>
			))
		}
		<a class="desktop-icon" href="/rss.xml">
			<span class="glyph">📡</span><span class="caption">RSS Feed</span>
		</a>
	</div>

	<Window title="Welcome — The Undercurrent Show" glyph="🌊" statusLeft="Ready" statusRight="Double-click an icon to begin">
		<div class="prose" style="max-width: 60ch;">
			<h1>The Undercurrent Show</h1>
			<p>
				Stories and ideas beneath the surface — essays, notes, and long-form
				writing on the things that move quietly under everything else.
			</p>
			<p>
				This is a home on the open web, dressed up like the desktop you grew up
				with. Open <strong>My Articles</strong> to start reading, or poke around
				the icons.
			</p>
			<p style="font-family: var(--readable);">
				<a href="/blog">
					<button style="font-family: inherit;">📖 Open My Articles</button>
				</a>
			</p>
		</div>
	</Window>
</Desktop>
