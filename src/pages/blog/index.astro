---
import { getCollection } from 'astro:content';
import Desktop from '../../layouts/Desktop.astro';
import Window from '../../components/Window.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const count = posts.length;
---

<Desktop
	title={`My Articles — ${SITE_TITLE}`}
	description="All articles from The Undercurrent Show."
	activeTitle="My Articles"
	activeGlyph="📖"
>
	<Window
		title="My Articles"
		glyph="📖"
		statusLeft={`${count} object${count === 1 ? '' : 's'}`}
		statusRight="The Undercurrent Show"
	>
		<div class="file-grid">
			{
				posts.map((post) => (
					<a class="file-item" href={`/blog/${post.id}/`}>
						<span class="glyph">📄</span>
						<span class="fname">{post.data.title}</span>
						<span class="fdate">
							<FormattedDate date={post.data.pubDate} />
						</span>
					</a>
				))
			}
		</div>
	</Window>
</Desktop>
